{
  "name": "auto-clicker",
  "private": true,
  "version": "2.0.0",
  "description": "Cross-platform auto clicker built with Electron, React, and TypeScript.",
  "main": "dist/main.js",
  "scripts": {
    "test": "node --test tests/clicker.test.js",
    "dev": "concurrently \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "build": "pnpm build:main && pnpm build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build --config vite.config.ts",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:mac": "pnpm build && electron-builder --mac"
  },
  "build": {
    "appId": "com.akiuse.auto-clicker",
    "productName": "Auto Clicker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "robotjs": "^0.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.0"
  }
}
